<section class="section__header">
    <div class="container">
        <div class="header-area">

            <div class="logotype">
                <a asp-controller="Home" asp-action="Index">
                    <img src="~/images/logotype.png" alt="CoreFitness Club" />
                </a>
            </div>

            <!-- Hamburgarknapp -->
            <button class="menu-toggle" id="mobile-menu" aria-label="Open Menu">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </button>

            <!-- Wrapper för menyer som ska döljas/visas -->
            <div class="nav-container">
                <nav class="main-menu">
                    <ul class="menu">
                        <li class="menu-item">
                            <a asp-controller="Home" asp-action="NotFoundPage" fragment="fitness-centers">Fitness Centers</a>
                        </li>
                        <li class="menu-item">
                            <a asp-controller="Memberships" asp-action="Index">Memberships</a>
                        </li>
                        <li class="menu-item">
                            <a asp-controller="Home" asp-action="Contact" fragment="training">Customer Service</a>
                        </li>
                        <li class="menu-item">
                            <a asp-controller="Booking" asp-action="Schedule" fragment="training">Training</a>
                        </li>
                        <li class="menu-item">
                            <a asp-controller="Home" asp-action="NotFoundPage" fragment="store">Store</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="menu-item">
                                <a asp-controller="Admin" asp-action="Index" style="color: var(--color-accent, #d4ff00); font-weight: bold;">Admin</a>
                            </li>
                        }
                    </ul>
                </nav>

                <nav class="account-menu">
                    <ul class="menu">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="menu-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn accent" style="border: none; cursor: pointer;">Sign Out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="menu-item">
                                <a class="menu-item-link" asp-controller="Account" asp-action="Register">Become Member</a>
                            </li>
                            <li class="menu-item">
                                <a class="btn accent" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>

        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuBtn = document.getElementById('mobile-menu');
        const nav = document.querySelector('.nav-container');

        if (menuBtn && nav) {
            menuBtn.addEventListener('click', function (e) {
                e.preventDefault();
                this.classList.toggle('is-active');
                
                if (nav.style.display === 'flex') {
                    nav.style.display = 'none';
                } else {
                    // Vi tvingar fram stilen direkt i HTML-taggen (vinner över all CSS)
                    nav.style.display = 'flex';
                    nav.style.flexDirection = 'column';
                    nav.style.position = 'absolute';
                    nav.style.top = '100%';
                    nav.style.left = '0';
                    nav.style.width = '100%';
                    nav.style.backgroundColor = '#171420';
                    nav.style.zIndex = '99999';
                    nav.style.padding = '40px 20px';
                }
                console.log("Meny-status: " + nav.style.display);
            });
        } else {
            console.error("Kunde inte hitta knappen eller nav-container!");
        }
    });
</script>