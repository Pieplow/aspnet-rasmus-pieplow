@model MembershipViewModel

@{
    ViewData["Title"] = "Our Memberships";
}

@* --- DYNAMISK MEDLEMSKAPS-SEKTION --- *@
<section class="section__membership">
    <div class="container">

        <div class="section__header" style="text-align:center;">
            <h2>Our Membership Offers</h2>
        </div>

        <div class="membership-grid">
            @foreach (var membership in Model.Memberships)
            {
                @* Om titeln innehåller "Premium" lägger vi till klassen highlight *@
                <div class="membership-card @(membership.Title.Contains("Premium", StringComparison.OrdinalIgnoreCase) ? "highlight" : "")">

                    <div class="card-icon">
                        @if (membership.Title.Contains("Standard", StringComparison.OrdinalIgnoreCase))
                        {
                            <text>⚙️</text>
                        }
                        else
                        {

                            <text>💎</text>
                        }
                    </div>

                    <div class="card-top">
                        <h3>@membership.Title</h3>
                        <ul class="features">
                            @foreach (var benefit in membership.Benefits)
                            {
                                <li>@benefit</li>
                            }
                        </ul>
                    </div>

                    <div class="card-bottom">
                        <div class="price-row">
                            <div>
                                <div class="price">@membership.Price.ToString("F2")</div>
                                <div class="price-sub">/monthly</div>
                            </div>

                            @* Knappen skickar användaren vidare till registrering *@
                            <a asp-controller="Account"
                               asp-action="SignUp"
                               asp-route-membershipId="@membership.Id"
                               class="btn accent">Join Now</a>
                        </div>

                        @if (membership.MonthlyClasses > 0)
                        {
                            <p class="price-sub" style="margin-top: 5px;">+ Monthly @membership.MonthlyClasses Classes</p>
                        }
                        <p class="trial">Try Any Membership Free for 1 Week</p>
                    </div>
                </div>
            }

           
            <div class="membership-cta">
                <h3>Get Your Membership</h3>
                <p>Our memberships give you access to all equipment, personal training.</p>
                <p class="phone">Call Us At: (+46) 8 410 521 00</p>
                <a href="tel:+46841052100" class="btn accent">Call Us Today</a>
            </div>
        </div>

        <div class="membership-benefits">
            <span>✔ Get 30 day free trial</span>
            <span>✔ No hidden fees</span>
            <span>✔ You can cancel anytime</span>
        </div>

    </div>
</section>

@* --- STATISK FAQ SEKTION --- *@
<section class="section__faq">
    <div class="container">
        <div class="faq-grid">

            <div class="faq-image">
                @* Kom ihåg att lägga in rätt sökväg till din bild här *@
                <img src="~/images/gym-training.jpg" alt="Gym training">
                </div>

                <div class="faq-content">
                    <span class="section-title accent">Frequently Asked Questions</span>
                    <h2>Common questions about gym and training</h2>

                    <div class="faq-item active">
                        <h4>Do I need prior gym experience?</h4>
                        <p>No, our gym is designed for all levels. Beginners get full guidance.</p>
                    </div>

                    <div class="faq-item">
                        <h4>What facilities are included?</h4>
                        <p>Full access to gym equipment, locker rooms, and sauna.</p>
                    </div>

                    <div class="faq-item">
                        <h4>Can I try the gym before joining?</h4>
                        <p>Yes, we offer a 1-week free trial for all new members.</p>
                    </div>

                    <div class="faq-item">
                        <h4>Are group workouts available?</h4>
                        <p>Yes, our Premium members have access to all group fitness classes.</p>
                    </div>

                    <div class="faq-item">
                        <h4>Is nutrition guidance included?</h4>
                        <p>Personal nutrition plans are available with our PT-packages.</p>
                    </div>

                </div>
            </div>
        </div>
    </section>