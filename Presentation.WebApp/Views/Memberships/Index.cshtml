@model MembershipViewModel

@{
    ViewData["Title"] = "Our Memberships";
}


<!-- Membership Section -->
<section class="section__membership">
    <div class="container">
        <div class="section__header">
            <h2>Our Membership Offers</h2>
        </div>

        <div class="membership-grid">
            <!-- STANDARD -->
            <div class="membership-card">
                <div class="card-icon">
                    <img src="~/images/bell.svg" alt="Icon">
                </div>
                <div class="card-top">
                    <h3>Standard Membership</h3>
                    <ul class="features">
                        <li>Standard Locker</li>
                        <li>High-energy group fitness classes</li>
                        <li>Motivating & supportive environment</li>
                    </ul>
                </div>
                <div class="card-bottom">
                    <div class="price-row">
                        <div class="price-group">
                            <div class="price">495.00 <span>/monthly</span></div>
                        </div>
                        <form asp-controller="Memberships" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Title" value="Standard Membership" />
                            <input type="hidden" name="Description" value="Standard Locker, high-energy group fitness classes" />
                            <input type="hidden" name="Price" value="495" />
                            <input type="hidden" name="MonthlyClasses" value="0" />
                            <button type="submit" class="btn accent">Join Now</button>
                        </form>
                    </div>
                    <p class="trial">Try Any Membership Free for 1 Week</p>
                </div>
            </div>

            <!-- PREMIUM -->
            <div class="membership-card highlight">
                <div class="card-icon">
                    <img src="~/images/bell.svg" alt="Icon">
                </div>
                <div class="card-top">
                    <h3>Premium Membership</h3>
                    <ul class="features">
                        <li>Priority Support & Premium Locker</li>
                        <li>High-energy group fitness classes</li>
                        <li>Motivating & supportive environment</li>
                    </ul>
                </div>
                <div class="card-bottom">
                    <div class="price-row">
                        <div class="price-group">
                            <div class="price">595.00 <span>/monthly</span></div>
                            <div class="price-sub">+ Monthly 20 Classes</div>
                        </div>
                        <form asp-controller="Memberships" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Title" value="Premium Membership" />
                            <input type="hidden" name="Description" value="Premium locker, priority support, group classes" />
                            <input type="hidden" name="Price" value="595" />
                            <input type="hidden" name="MonthlyClasses" value="20" />
                            <button type="submit" class="btn accent">Join Now</button>
                        </form>
                    </div>
                    <p class="trial">Try Any Membership Free for 1 Week</p>
                </div>
            </div>

            <!-- CTA - NU INUTI GRIDDEN -->
            <div class="membership-cta">
                <div class="cta-content">
                    <h3>Get Your Membership</h3>
                    <p>Our memberships give you access to all equipment, personal training.</p>
                    <p class="phone">Call Us At: (+46) 8 410 521 00</p>
                    <a href="#" class="btn accent">Call Us Today</a>
                </div>
                <div class="cta-image">
                    <img src="~/images/our-pricing-cta-image 1.png" alt="Training Image">
                </div>
            </div>
        </div> <!-- Slut på membership-grid -->

        <div class="membership-benefits">
            <span>✔ Get 30 day free trial</span>
            <span>✔ No hidden fees</span>
            <span>✔ You can cancel anytime</span>
        </div>
    </div>
</section>
    <section class="section__faq">
   
                <div class="faq-section">
                    <div class="faq-grid">
                        <div class="faq-image">
                            <img src="~/images/faqs-image 1.png" alt="Bodybuilder">
                        </div>

                        <div class="faq-content">
                            <span class="faq-label">• Frequently Asked Questions</span>
                            <h2>Common questions about gym and training</h2>

                            <div class="faq-list" id="faqList">
                                <div class="faq-item active">
                                    <h4>
                                        Q1. Do I need prior gym experience to Join CoreFitness?
                                        <span class="arrow-container"><span class="arrow">▲</span></span>
                                    </h4>
                                    <div class="faq-answer">
                                        <p>No, GymPro is designed for all fitness levels. Our trainers guide beginners with proper techniques and structured workout plans to help them start safely and confidently.</p>
                                        <ul>
                                            <li>Every new member receives a personalized introduction to equipments</li>
                                            <li>Workouts are designed to grow with you, ensuring beginners can start safely</li>
                                        </ul>
                                    </div>
                                </div>

                                <div class="faq-item">
                                    <h4>
                                        Q2. What facilities are included with the membership?
                                        <span class="arrow-container"><span class="arrow">▼</span></span>
                                    </h4>
                                    <div class="faq-answer">
                                        <p>Our memberships include access to all cardio and strength equipment, locker rooms, and selected group fitness classes.</p>
                                    </div>
                                </div>

                                <div class="faq-item">
                                    <h4>
                                        Q3. Can I try the gym before taking a membership?
                                        <span class="arrow-container"><span class="arrow">▼</span></span>
                                    </h4>
                                    <div class="faq-answer">
                                        <p>Yes! We offer a 1-week free trial for all new local residents. Simply bring a valid ID and we will get you started.</p>
                                    </div>
                                </div>

                                <div class="faq-item">
                                    <h4>
                                        Q4. Are there group workout programs available?
                                        <span class="arrow-container"><span class="arrow">▼</span></span>
                                    </h4>
                                    <div class="faq-answer">
                                        <p>Absolutely. We offer HIIT, Yoga, Power Lifting, and Cardio classes weekly. Check our schedule section for timings.</p>
                                    </div>
                                </div>

                                <div class="faq-item">
                                    <h4>
                                        Q5. Is nutrition guidance included in the plans?
                                        <span class="arrow-container"><span class="arrow">▼</span></span>
                                    </h4>
                                    <div class="faq-answer">
                                        <p>Nutrition counseling is available as an add-on service or included in our Premium membership levels.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
              </section>
                <script>
                                    document.getElementById('faqList')?.addEventListener('click', function(e) {
                                        const item = e.target.closest('.faq-item');
                                        if (!item) return;

                                        const isActive = item.classList.contains('active');
        
                                        document.querySelectorAll('.faq-item').forEach(el => {
                                            el.classList.remove('active');
                                            const arrow = el.querySelector('.arrow');
                                            if (arrow) arrow.textContent = '▼';
                                        });

                                        if (!isActive) {
                                            item.classList.add('active');
                                            const arrow = item.querySelector('.arrow');
                                            if (arrow) arrow.textContent = '▲';
                                        }
                                    });
                </script>