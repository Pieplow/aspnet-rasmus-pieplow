@model IEnumerable<Application.GymClasses.Responses.GymClassResponse>

<!-- Admin Dashboard -->
<section class="section__bookings">
    <div class="container">
        <header class="section__header-wide">
            <h2>Admin Dashboard</h2>
            <p>Manage gym classes and bookings</p>
        </header>

        <div class="account-dashboard-grid">
            <!-- Sidebar: Add Form -->
            <aside class="dashboard-sidebar">
                <div class="admin-card">
                    <h3 class="admin-card-title">Add New Class</h3>
                    <form asp-controller="Admin" asp-action="Create" method="post">
                        @Html.AntiForgeryToken() 
    
                        <div class="form-group">
                            <label>Class Title</label>
                            <input name="Name" type="text" placeholder="e.g. Yoga" class="form-input" required />
                        </div>
                        <div class="form-group">
                            <label>Date & Time</label>
                            <input name="StartTime" type="datetime-local" class="form-input" required />
                        </div>
                        <div class="form-group">
                            <label>Instructor</label>
                            <input name="Trainer" type="text" placeholder="Instructor name" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>Capacity</label>
                            <input name="MaxCapacity" type="number" placeholder="20" class="form-input" required />
                        </div>
                        <button type="submit" class="btn accent btn--full">
                            Create Class +
                        </button>
                    </form>
                </div>
            </aside>

            <!-- Main: Class Table -->
            <main class="dashboard-content">
                <div class="admin-card admin-card--table">
                    <div class="nav-header">Existing Classes</div>
                    <div class="table-container">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Class info</th>
                                    <th>Instructor</th>
                                    <th>Bookings</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        
                                        <td>
                                            <div class="admin-table-main">@item.Name</div>
                                            <div class="admin-table-sub">@item.StartTime.ToString("f")</div>
                                        </td>

                                       
                                        <td>@item.Trainer</td>

                                        
                                        <td><span class="admin-badge">0 / @item.MaxCapacity</span></td>

                                        
                                        <td>
                                            <div style="display: flex; gap: 10px; align-items: center;">
                                                
                    
                                              
                                                <form action="/admin/delete/@item.Id" method="post" onsubmit="return confirm('Vill du verkligen ta bort @item.Name?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                  
                                                    <button type="submit" class="admin-action admin-action--delete">Remove Class</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>
</section>
