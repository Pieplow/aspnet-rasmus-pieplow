<!-- My Bookings Page -->
<section class="section__bookings">
    <div class="container">
        <header class="section__header-wide">
            <h2>My Booked Classes</h2>
            <p>Manage your upcoming training sessions</p>
        </header>

        <div class="bookings-grid">
            <!-- Booking Card -->
            @if (Model?.Any() != true)
            {
                <div class="booking-card booking-card--empty">
                    <p>No bookings yet</p>
                    <a href="/Classes" class="btn accent">
                        Browse Classes →
                    </a>
                </div>
            }
            else
            {
                foreach (var booking in Model)
                {
                    <div class="booking-card">
                        <span class="status-tag">Confirmed</span>

                        <h4>@booking.Title</h4>

                        <div class="info">
                            <span>📅 @booking.BookedAt.ToString("yyyy-MM-dd")</span>
                            <span>⏰ @booking.Time</span>
                            <span>👤 @booking.Instructor</span>
                        </div>

                        <div class="booking-card-footer">
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                <button type="submit" class="delete-link">
                                    🗑 Cancel Booking
                                </button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>
