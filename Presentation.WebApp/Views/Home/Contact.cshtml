<!-- Contact Section -->
<section class="section__contact">
    <div class="container">
        <div class="contact-card">
            <div class="contact-grid">
                <!-- Left: Image & Info -->
                <div class="contact-visual">
                    <img src="~/images/contact-us-image 1.png" /> alt="Fitness Woman">
                    <div class="contact-info-box">
                        <div class="info-item">
                            <div class="icon">📞</div>
                            <div class="details">
                                <label>Phone Number</label>
                                <span>+(46) 8 410 521 00</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="icon">✉</div>
                            <div class="details">
                                <label>Email Address</label>
                                <span>info@corefitness.se</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Form -->
                <div class="contact-form-area">
                    <h3>Contact Us Today</h3>
                    <p class="intro">Ready to begin your fitness journey? Contact GymPro today and let our expert trainers guide you with the right program and support.</p>

                    <form asp-controller="Home" asp-action="Contact" method="post">
                        <div class="form-row">
                            <div class="form-group">
                                <label>First Name *</label>
                                <input type="text" name="firstName" placeholder="Enter First Name">
                            </div>
                            <div class="form-group">
                                <label>Last Name *</label>
                                <input type="text" name="lastName" placeholder="Enter Last Name">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Email Address *</label>
                                <input type="email" name="email" placeholder="Enter Email Address">
                            </div>
                            <div class="form-group">
                                <label>Phone Number</label>
                                <input type="tel" name="phone" placeholder="Enter Phone Number">
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Message *</label>
                            <textarea name="Message" placeholder="message.."></textarea>
                        </div>

                        <button type="submit" class="btn accent">Submit Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section__faq">
   
    <div class="faq-section">
        <div class="faq-grid">
            <div class="faq-image">
                <img src="~/images/faqs-image 1.png" alt="Bodybuilder">
            </div>

            <div class="faq-content">
                <span class="faq-label">• Frequently Asked Questions</span>
                <h2>Common questions about gym and training</h2>

                <div class="faq-list" id="faqList">
                    <div class="faq-item active">
                        <h4>
                            Q1. Do I need prior gym experience to Join CoreFitness?
                            <span class="arrow-container"><span class="arrow">▲</span></span>
                        </h4>
                        <div class="faq-answer">
                            <p>No, GymPro is designed for all fitness levels. Our trainers guide beginners with proper techniques and structured workout plans to help them start safely and confidently.</p>
                            <ul>
                                <li>Every new member receives a personalized introduction to equipments</li>
                                <li>Workouts are designed to grow with you, ensuring beginners can start safely</li>
                            </ul>
                        </div>
                    </div>

                    <div class="faq-item">
                        <h4>
                            Q2. What facilities are included with the membership?
                            <span class="arrow-container"><span class="arrow">▼</span></span>
                        </h4>
                        <div class="faq-answer">
                            <p>Our memberships include access to all cardio and strength equipment, locker rooms, and selected group fitness classes.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <h4>
                            Q3. Can I try the gym before taking a membership?
                            <span class="arrow-container"><span class="arrow">▼</span></span>
                        </h4>
                        <div class="faq-answer">
                            <p>Yes! We offer a 1-week free trial for all new local residents. Simply bring a valid ID and we will get you started.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <h4>
                            Q4. Are there group workout programs available?
                            <span class="arrow-container"><span class="arrow">▼</span></span>
                        </h4>
                        <div class="faq-answer">
                            <p>Absolutely. We offer HIIT, Yoga, Power Lifting, and Cardio classes weekly. Check our schedule section for timings.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <h4>
                            Q5. Is nutrition guidance included in the plans?
                            <span class="arrow-container"><span class="arrow">▼</span></span>
                        </h4>
                        <div class="faq-answer">
                            <p>Nutrition counseling is available as an add-on service or included in our Premium membership levels.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>