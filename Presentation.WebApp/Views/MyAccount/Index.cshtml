@model Presentation.WebApp.ViewModels.MyAccountViewModel

@{
    ViewData["Title"] = "My Account";
}

<section class="section__account-dashboard">
    <div class="container">
        <header class="text-center" style="margin-bottom: 4rem;">
            <h2 style="font-size: 3rem; text-transform: uppercase; letter-spacing: -0.05em;">My Account</h2>
        </header>

        <div class="account-dashboard-grid">
            
            <!-- SIDEBAR -->
            <aside class="dashboard-sidebar">
                <div class="profile-photo">
                    <img src="https://images.unsplash.com/photo-1597347343908-2937e7dcc560?auto=format&fit=crop&q=80&w=1000"
                         alt="Profile">
                </div>

                @if (Model.Membership != null)
                {
                    <div class="membership-card">
                        <h3>Your Membership</h3>
                        <h4>@Model.Membership.Title</h4>
                        <p>@Model.Membership.Description</p>
                        <p>@Model.Membership.Price kr</p>
                    </div>
                }

                <nav class="sidebar-nav-card">
                    <div class="nav-header">Menu Options</div>
                    <ul class="nav-links">
                        <li>
                            <a asp-controller="MyAccount" asp-action="Index">
                                <span style="color: var(--accent-dark);">About Me</span>
                                <span class="arrow">▶</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="MyAccount" asp-action="NotFoundPage"><span>My Membership</span><span class="arrow">▶</span></a>
                        </li>
                        <li>
                            <a asp-controller="Booking" asp-action="MyBookings"><span>My Bookings</span><span class="arrow">▶</span></a>
                        </li>
                        <li>
                            <!-- Logout ligger kvar i AccountController eftersom det rör säkerhet/auth -->
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:none;border:none;color:inherit;cursor:pointer;">
                                    <span>Sign Out</span> ▶
                                </button>
                            </form>
                        </li>
                    </ul>
                </nav>

                <div class="account-delete-area">
                    <p>If you like to remove your account click below</p>
                    <!-- Ändrad till MyAccountController -->
                    <form asp-controller="MyAccount" asp-action="DeleteAccount" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="delete-link">Remove Account</button>
                    </form>
                </div>
            </aside>

            <!-- MAIN CONTENT -->
            <main class="dashboard-content">
                @if (TempData["Success"] != null)
                {
                    <div id="success-alert" class="alert-success-custom">
                        @TempData["Success"]
                    </div>
                }
                <div class="about-me-card">
                    <h3>About Me</h3>

                    <!-- Ändrad till MyAccountController -->
                    <form asp-controller="MyAccount" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-row">
                            <div class="form-group">
                                <label>First Name</label>
                                <input type="text" name="firstName" value="@Model.FirstName" class="form-input" />
                            </div>

                            <div class="form-group">
                                <label>Last Name</label>
                                <input type="text" name="lastName" value="@Model.LastName" class="form-input" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" value="@Model.Email" readonly class="form-input" />
                        </div>

                        <div class="form-group">
                            <label>Phone Number</label>
                            <input type="tel" name="phoneNumber" value="@Model.PhoneNumber" class="form-input" />
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn accent gym-button-hover">
                                Save Profile
                            </button>
                        </div>
                    </form>
                </div>

                <!-- STATISTICS (Behålls som de är) -->
                <div class="statistics-section">
                    <h3>My Statistics</h3>
                    <div class="stats-card">
                        <div class="stat-item">
                            <div class="stat-info">
                                <span>Check-In (last 30 days)</span>
                                <span>25</span>
                            </div>
                            <div class="stat-bar">
                                <div class="progress-fill" style="width: 83%;"></div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-info">
                                <span>Weight Goal</span>
                                <span>50%</span>
                            </div>
                            <div class="stat-bar">
                                <div class="progress-fill" style="width: 50%;"></div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-info">
                                <span>Current BMI</span>
                                <span>27</span>
                            </div>
                            <div class="stat-bar">
                                <div class="progress-fill" style="width: 65%;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const alert = document.getElementById('success-alert');
            if (alert) {
                setTimeout(() => {
                    alert.style.transition = "opacity 1s ease";
                    alert.style.opacity = "0";
                    setTimeout(() => alert.remove(), 1000);
                }, 3000);
            }
        });
    </script>
}