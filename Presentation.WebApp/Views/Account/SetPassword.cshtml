<section class="section__account">
    <div class="container flex-center">
        <div class="account-card">
            <h3>Set Your Password</h3>
            <p class="intro">Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>

            <form asp-controller="Account" asp-action="SetPassword" method="post">

                <div asp-validation-summary="All"></div>

                <input type="hidden" name="email" value="@ViewBag.Email" />

                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" value="@ViewBag.Email" readonly />
                </div>

                <div class="form-group">
                    <label>Password *</label>
                    <input type="password" name="password" class="form-input" />
                </div>

                <button type="submit" class="btn accent">Continue</button>
          

                
                


            </form>
        </div>
    </div>
</section>
