<section class="section__account">
    <div class="container flex-center">
        <div class="account-card">
            <h3>Set Your Password</h3>
            <p class="intro">Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>

            <form method="post">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" class="form-input" value="username@domain.com" readonly />
                </div>

                <div class="form-group">
                    <label>Password *</label>
                    <input type="password" class="form-input" placeholder="Enter Password" aria-required="true" />
                </div>

                <button type="submit" class="btn accent btn--full">
                    Continue <span class="btn-arrow">›</span>
                </button>

                <div class="terms-check">
                    <input type="checkbox" id="acceptTerms" />
                    <label for="acceptTerms">Accept user terms and conditions</label>
                </div>
            </form>
        </div>
    </div>
</section>
