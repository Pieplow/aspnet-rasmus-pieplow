<section class="section__account">
    <div class="container flex-center">
        <div class="account-card">
            <h3>Welcome Back!</h3>
            <p class="intro">
                Log in to continue your fitness journey with full access to your customized program, training history and progress tracking.
            </p>
            @if (TempData["StatusMessage"] != null)
            {
                <div style="color: #ce3d3d; background: #fff5f5; border: 1px solid #ce3d3d; padding: 0.8rem; margin-bottom: 1rem; border-radius: 4px; font-size: 0.9rem; text-align: center; font-weight: 500;">
                    @TempData["StatusMessage"]
                </div>
            }

            <!-- FORM 1: SOCIAL LOGIN (Dina snygga knappar med ikoner) -->
            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div class="social-login">
                    
                    @* Google-knappen *@
                    <button type="submit" name="provider" value="Google" class="social-btn" title="Log in with Google">
                        <img src="~/images/googlechrome-icon.svg"
                             alt="Google"
                             style="width: 20px; height: 20px; object-fit: contain; pointer-events: none;" />
                    </button>
                    
                    @* GitHub-knappen *@
                    <button type="submit" name="provider" value="GitHub" class="social-btn" title="Log in with GitHub">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/9/91/Octicons-mark-github.svg"
                             alt="GitHub"
                             style="width: 22px; height: 22px; object-fit: contain; pointer-events: none;" />
                    </button>
                    
                </div>
            </form>

            <div class="divider">OR CONTINUE WITH</div>

            <!-- FORM 2: VANLIG LOGIN (Email & Lösenord) -->
            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                
                <div class="form-group">
                    <label>Email Address *</label>
                    <input name="email" class="form-input" placeholder="Enter Email Address" />
                </div>

                <div class="form-group">
                    <div class="flex-between">
                        <label>Password *</label>
                        <a href="#" class="forgot-link">Forgot your password?</a>
                    </div>
                    <input name="password" type="password" class="form-input" placeholder="Enter Password" />
                </div>

                <button type="submit" class="btn accent w-full">Log in</button>

                <div class="terms-check">
                    <input type="checkbox" name="rememberMe" />
                    <label>Remember me</label>
                </div>
            </form>
        </div>
    </div>
</section>