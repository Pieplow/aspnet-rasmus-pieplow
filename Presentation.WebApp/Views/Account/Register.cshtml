<!-- Signup Section -->
<section class="section__account">
    <div class="container flex-center">
        <div class="account-card text-center">
            <h3>Become a Member</h3>
            <p class="intro">Sign up to continue your fitness journey with full access to your account.</p>

            <!-- FORM 1: SOCIAL REGISTER (Kopplad till Google/GitHub) -->
            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <div class="social-login">
                    @* Google-knapp med ikon *@
                    <button type="submit" name="provider" value="Google" class="social-btn" title="Sign up with Google">
                        <img src="~/images/googlechrome-icon.svg"
                             alt="Google"
                             style="width: 20px; height: 20px; object-fit: contain; pointer-events: none;" />
                    </button>
                    
                    @* GitHub-knapp med ikon (ersätter F) *@
                    <button type="submit" name="provider" value="GitHub" class="social-btn" title="Sign up with GitHub">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/9/91/Octicons-mark-github.svg"
                             alt="GitHub"
                             style="width: 22px; height: 22px; object-fit: contain; pointer-events: none;" />
                    </button>
                </div>
            </form>

            <div class="divider">OR CONTINUE WITH</div>

            <!-- FORM 2: VANLIG REGISTER (Email) -->
            <form id="registerForm" asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group text-left">
                    <label>Email Address *</label>
                    <input name="Email" class="form-input" autocomplete="username" placeholder="Enter Email Address" />
                </div>

                <button id="registerSubmit" type="submit" class="btn accent w-full">Register</button>

                <p class="verification-note">We will send a verification code to your email address.</p>
            </form>
        </div>
    </div>
</section>