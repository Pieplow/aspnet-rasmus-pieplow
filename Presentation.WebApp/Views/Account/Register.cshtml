<!-- Signup Section -->
<section class="section__account">
    <div class="container flex-center">
        <div class="account-card text-center">
            <h3>Become a Member</h3>
            <p class="intro">Sign up to continue your fitness journey with full access to your account.</p>

            <!-- SOCIAL (placeholder – behåll design) -->
            <form id="external-account-reg" method="post">
                <div class="social-login">
                    <button type="button" class="social-btn"><span>G</span></button>
                    <button type="button" class="social-btn"><span>F</span></button>
                </div>
            </form>

            <div class="divider">OR CONTINUE WITH</div>

            <!-- 🔥 MVC FORM (ENDA riktiga ändringen) -->
            <form id="registerForm" asp-controller="Account" asp-action="Register" method="post">

                <div class="form-group text-left">
                    <label>Email Address *</label>
                    <input name="Email" class="form-input" autocomplete="username" placeholder="Enter Email Address" />
                </div>

                <button id="registerSubmit" type="submit" class="btn accent w-full">Register</button>

                <p class="verification-note">We will send a verification code to your email address.</p>
            </form>
        </div>
    </div>
</section>